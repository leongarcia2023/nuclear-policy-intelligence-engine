# Copy to .env (gitignored). The build runs end-to-end with ALL of these blank.
#
# LLM provider selection. DEFAULT is the deterministic rules engine — no key, $0.
#   deterministic | anthropic | local
LLM_PROVIDER=deterministic

# Only read when LLM_PROVIDER=anthropic. The adapter is inert without it.
ANTHROPIC_API_KEY=

# LegiScan FREE key. If absent, the pipeline runs on gold_seed.jsonl fixtures.
LEGISCAN_API_KEY=
