# ADVERSARIAL SET — same indirect CONCEPTS the README headlines (silent inclusion,
# silent exclusion, co-location, cost-recovery bars), phrased the way a real drafter
# plausibly would, but DELIBERATELY avoiding the current regex tells in
# src/classify/ontology.ts + deterministic.ts. Labels are TRUE analyst judgments.
#
# This bucket is NON-GATING. It is EXPECTED to score low: that low recall is the
# whole point — it measures how brittle keyword/regex matching is against real
# phrasing. The gap between this and the tuning set's 100% is the deliverable.
#
# HARD RULE: do NOT widen the regexes to make these pass. That is the exact failure
# mode (overfitting the instrument) this set exists to expose. If the deterministic
# classifier should catch these, that is an argument for the LLM provider, not for
# editing ontology.ts.
{"id": "adv-001", "state": "AZ", "bill_number": "HB 2451", "title": "Clean Power Program Act", "text": "An Act concerning the state clean power program. For purposes of this Act, a qualified clean generation facility is one that emits no greenhouse gases in the course of producing electricity and can supply power around the clock, independent of weather conditions. Each electric utility shall ensure that an increasing share of delivered energy originates from qualified clean generation facilities.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "Inclusion via synonyms ('emits no greenhouse gases','around the clock','independent of weather'); term ends in 'facility' so no 'means' capture. Should be caught as indirect-helps; expected MISS."}
{"id": "adv-002", "state": "NV", "bill_number": "SB 318", "title": "Low-Carbon Electricity Target Act", "text": "An Act establishing a low-carbon electricity target. The commission shall give procurement preference to non-intermittent, continuously available generators that do not emit carbon during operation. Such generators provide essential grid stability and shall count fully toward the state's low-carbon electricity target.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility", "carbon_procurement"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "'non-intermittent','continuously available','low-carbon' instead of firm/dispatchable/zero-carbon. Expected MISS."}
{"id": "adv-003", "state": "OR", "bill_number": "HB 3120", "title": "Renewable Power Expansion Act", "text": "An Act to expand renewable power. Eligible renewable technology is limited to wind turbines, solar photovoltaic arrays, geothermal wells, and run-of-river hydro. Beginning in 2030, load-serving entities must meet seventy percent of demand using eligible renewable technologies, and the commission may not authorize recovery of capital costs for any thermal generating station placed in service thereafter.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility", "definitions_trap", "rate_recovery_securitization"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "high"}, "note": "Closed renewable list excludes nuclear; term ends 'technology', 'is limited to' (no 'means'); cost bar phrased 'may not authorize recovery of capital costs'. Green-but-excludes-nuclear. Expected MISS."}
{"id": "adv-004", "state": "NM", "bill_number": "SB 207", "title": "Clean Electricity Program Act", "text": "An Act relating to the clean electricity program. For purposes of this Act, a clean energy facility means a facility whose generation emits no carbon dioxide and provides dependable output throughout the year. By 2032, at least sixty percent of retail electricity sales must come from clean energy facilities.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "Defined term ends 'facility' so '(resource|source|generation) means' capture misses; 'program' avoids the 'standard' tell. Expected MISS."}
{"id": "adv-005", "state": "CO", "bill_number": "HB 24-1310", "title": "Utility Cost Allocation Act", "text": "An Act concerning utility cost allocation. No authorization shall be granted for the recovery of construction costs associated with steam-electric generating units commissioned after January 1, 2030. Utilities are directed to prioritize investments that do not rely on combustion or steam cycles.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": false, "primary_vectors": ["rate_recovery_securitization"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "high"}, "note": "Cost-recovery bar on steam-electric (nuclear is steam-cycle) phrased passively ('No authorization shall be granted for the recovery of construction costs'); avoids 'shall not approve' and 'cost recovery'. Expected MISS."}
{"id": "adv-006", "state": "WA", "bill_number": "SB 5910", "title": "Clean Grid Advancement Act", "text": "An Act to advance the clean grid. The commission may not authorize cost-of-service recovery for new thermal generation that combusts fuel or boils water to drive a turbine. Resources that generate without thermal cycles shall be favored in all future procurements.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["rate_recovery_securitization", "clean_standard_eligibility"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "high"}, "note": "'may not authorize cost-of-service recovery' for thermal; nuclear is thermal. Avoids 'shall not approve' and the exact 'cost recovery' token. Expected MISS."}
{"id": "adv-007", "state": "TX", "bill_number": "HB 4488", "title": "Capacity Accreditation Act", "text": "An Act concerning capacity accreditation. The commission shall adopt an effective load carrying capability methodology that accredits each generator according to its contribution during the highest-risk winter and summer hours. Generators capable of sustained output during multi-day cold snaps shall receive capacity payments commensurate with their measured reliability contribution.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "Structural signal, NO definitions clause. ELCC accreditation rewards nuclear's high capacity value vs intermittent. Ontology has no dedicated capacity-accreditation vector (closest labeled: clean_standard_eligibility). Expected MISS."}
{"id": "adv-008", "state": "PA", "bill_number": "HB 2207", "title": "Winter Reliability Program Act", "text": "An Act establishing a winter reliability program. The grid operator shall make availability payments to generating units that demonstrate firm fuel arrangements and the ability to run continuously for at least ninety-six hours during extreme cold. Units that fail to perform during declared cold-weather events shall forfeit such payments.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": false, "primary_vectors": ["clean_standard_eligibility"], "direction": "helps", "expected_position": "support", "materiality_band": "medium"}, "note": "Availability/performance payments reward on-site-fueled, continuously-running units (nuclear). 'firm fuel arrangements' is not 'firm dispatchable'. No definitions clause. Expected MISS."}
{"id": "adv-009", "state": "OH", "bill_number": "SB 244", "title": "Eligible Clean Generation Act", "text": "An Act concerning eligible clean generation. A generating unit qualifies as clean if it is dispatchable and firm and produces electricity with no associated carbon dioxide. The state's clean generation goal shall be met using such qualifying units.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "Reversed token order 'dispatchable and firm' evades the firm-then-dispatchable tell; 'no associated carbon dioxide' evades 'zero-carbon'; 'qualifies as clean if' has no 'means'. Expected MISS."}
{"id": "adv-010", "state": "IL", "bill_number": "HB 3702", "title": "Qualifying Clean Power Act", "text": "An Act to define qualifying clean power. The following are qualifying clean power sources: solar photovoltaic and onshore wind. Geothermal and small hydroelectric are also qualifying. No other generating technology may be counted toward the clean power requirement, and no capital recovery shall be available for generation that boils water to produce steam.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility", "definitions_trap", "rate_recovery_securitization"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "high"}, "note": "Enumeration split across sentences (no 'means', no single closed list); 'no capital recovery' for steam generation excludes nuclear. Expected MISS."}
{"id": "adv-011", "state": "NY", "bill_number": "AB 1559", "title": "Energy and Health Omnibus Act", "text": "An Act relating to energy and health. Title I: The commission shall establish a procurement preference for generation that runs continuously and emits no carbon, ensuring grid reliability. Title II: The Department of Health shall license facilities administering radiopharmaceuticals and diagnostic nuclear imaging, and shall set credentialing standards for nuclear medicine technologists.", "labels": {"relevant": true, "is_indirect": false, "model_bill_risk": false, "primary_vectors": ["clean_standard_eligibility", "carbon_procurement"], "direction": "helps", "expected_position": "support", "materiality_band": "medium"}, "note": "Bundled: Title I is in-scope (firm clean procurement preference -> helps nuclear); Title II is out-of-scope nuclear medicine. is_indirect=false (a 'nuclear' keyword search surfaces it via Title II, as a false friend). Tests whether the scope gate wrongly rejects the whole bill on the medical markers. Expected MISS (over-rejected)."}
{"id": "adv-012", "state": "VA", "bill_number": "HB 1733", "title": "Dedicated Generation for High-Demand Customers Act", "text": "An Act concerning dedicated generation for high-demand customers. A customer whose electricity demand exceeds two hundred fifty thousand kilowatts may site a generating station on the same premises and consume its output directly without using the transmission network. Such arrangements shall not impose costs on other customers.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["large_load_colocation", "interconnection_transmission"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "Co-location ENABLING for a >100MW load, but 'site on the same premises and consume its output directly' avoids 'co-locate'/'behind the meter'; '250 thousand kilowatts' avoids the MW-digit tell. The hyperscaler-nuclear surface. Expected MISS."}
{"id": "adv-013", "state": "PA", "bill_number": "SB 655", "title": "On-Site Power Arrangements Act", "text": "An Act concerning on-site power arrangements. A retail customer that obtains electricity from a generating facility on its own premises shall remit a network access fee equal to the distribution charges it would otherwise have paid. The commission shall deny any on-site arrangement found to raise costs for the remaining customer base.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["large_load_colocation", "rate_recovery_securitization"], "direction": "hurts", "expected_position": "amend", "materiality_band": "high"}, "note": "Restricts behind-the-meter co-location via a network access fee + cost-shift denial, but avoids 'co-locate','behind the meter','grid-service charge','shift costs'. Expected MISS."}
{"id": "adv-014", "state": "GA", "bill_number": "HB 884", "title": "Advanced Manufacturing Promotion Act", "text": "An Act to promote advanced manufacturing. To qualify for the Advanced Industry Tax Credit, a facility must source its electricity from approved clean generators, defined for purposes of this section as wind, solar, and battery storage installations. Electricity from other sources shall not count toward the credit's clean-sourcing threshold.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["definitions_trap", "clean_standard_eligibility"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "medium"}, "note": "Definitions trap buried in a non-energy tax bill; 'approved clean generators, defined ... as wind, solar, and battery storage' silently excludes nuclear. No 'means', no quotes. Expected MISS."}
{"id": "adv-015", "state": "MI", "bill_number": "SB 462", "title": "Energy Mix Modernization Act", "text": "An Act modernizing the energy mix. Generators that emit no greenhouse gases shall be issued tradable clean attributes for each megawatt-hour produced, and load-serving entities must surrender clean attributes covering an increasing percentage of their retail sales.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility", "carbon_procurement"], "direction": "helps", "expected_position": "support", "materiality_band": "high"}, "note": "Clean-attribute (CES) crediting that includes nuclear via 'emit no greenhouse gases'; avoids zero-carbon/portfolio-standard tells and 'procurement mechanism'. Expected MISS."}
{"id": "adv-016", "state": "MN", "bill_number": "HF 905", "title": "Renewable Future Act", "text": "An Act for a renewable future. Only energy derived from naturally replenished flows, namely sunlight, wind, water, and the earth's heat, may satisfy the renewable energy obligation established by this Act. The commission shall not extend ratemaking support to other generating methods.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility", "rate_recovery_securitization"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "high"}, "note": "'naturally replenished flows' enumerates renewables and excludes nuclear; 'shall not extend ratemaking support' bars cost recovery. Avoids 'means','standard','cost recovery','shall not approve'. Expected MISS."}
{"id": "adv-017", "state": "NC", "bill_number": "SB 612", "title": "Grid Access for New Generators Act", "text": "An Act concerning grid access for new generators. The grid operator shall give scheduling priority in the study process to generators that provide year-round, weather-independent output, shortening their wait for grid connection.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": false, "primary_vectors": ["interconnection_transmission"], "direction": "helps", "expected_position": "monitor", "materiality_band": "medium"}, "note": "Interconnection/queue reform favoring firm weather-independent generation (nuclear), but 'grid connection'/'study process' avoid 'interconnection'/'queue'/'cluster study'. Expected MISS."}
{"id": "adv-018", "state": "TX", "bill_number": "SB 1290", "title": "Capacity Market Reform Act", "text": "An Act concerning capacity markets. Each generator shall receive a qualifying capacity value reflecting its availability during system peaks; resources able to deliver without interruption regardless of weather shall receive the highest qualifying capacity value.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": false, "primary_vectors": ["clean_standard_eligibility"], "direction": "helps", "expected_position": "support", "materiality_band": "medium"}, "note": "'qualifying capacity' likely trips the vector so this is CAUGHT as relevant/indirect, but with no definitions clause the direction analysis returns neutral while the true direction is helps: a direction-agreement miss even when recall counts it."}
{"id": "adv-019", "state": "OH", "bill_number": "HB 412", "title": "Clean Portfolio Standard Update Act", "text": "An Act on clean portfolio standards. The renewable portfolio standard is hereby increased to eighty percent of retail sales. Qualifying technologies are limited to those listed in subsection (c), which does not include any generating unit that relies on a steam cycle.", "labels": {"relevant": true, "is_indirect": true, "model_bill_risk": true, "primary_vectors": ["clean_standard_eligibility", "definitions_trap"], "direction": "hurts", "expected_position": "oppose", "materiality_band": "high"}, "note": "'renewable portfolio standard' and 'qualifying technologies' trip the vector (likely CAUGHT), but with no 'means' clause and a prose exclusion of steam-cycle units, the direction returns neutral while the true direction is hurts: a direction-agreement miss."}
